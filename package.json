{
  "name": "opencode-session-tracker",
  "version": "2.3.17",
  "description": "OpenCode TUI plugin & Telegram Integration - Track active sessions/subagents in the sidebar and interact remotely from your phone",
  "type": "module",
  "exports": {
    "./tui": "./dist/index.tsx"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && cp -R src dist",
    "dev": "node -e \"const f=require('fs'),c=()=>{try{f.cpSync('src','dist',{recursive:true});console.log('built',new Date().toLocaleTimeString())}catch(e){}};if(!f.existsSync('dist'))f.mkdirSync('dist');c();f.watch('src',{recursive:true},c);console.log('watching...')\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "sidebar",
    "sessions"
  ],
  "license": "MIT",
  "author": "ykocaman",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ykocaman/opencode-session-tracker.git"
  },
  "engines": {
    "opencode": ">=1.4.3"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.18.0",
    "@opentui/core": "^0.4.3",
    "@opentui/solid": "^0.4.3",
    "node-telegram-bot-api": "^0.66.0",
    "solid-js": "^1.9.14"
  },
  "devDependencies": {
    "@types/node-telegram-bot-api": "^0.64.15",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2"
  }
}
