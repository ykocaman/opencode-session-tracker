{
  "name": "opencode-session-tracker",
  "version": "2.0.1",
  "description": "OpenCode TUI plugin - list and switch between sessions in the sidebar",
  "type": "module",
  "exports": {
    "./tui": "./dist/tui.tsx"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && mkdir -p dist && cp src/index.tsx dist/tui.tsx && cp src/telegram.ts dist/telegram.ts",
    "dev": "node -e \"const f=require('fs'),s=['src/index.tsx','src/telegram.ts'],d=['dist/tui.tsx','dist/telegram.ts'],c=()=>{s.forEach((p,i)=>{try{f.cpSync(p,d[i])}catch(e){}});console.log('built',new Date().toLocaleTimeString())};if(!f.existsSync('dist'))f.mkdirSync('dist');c();s.forEach(p=>f.watch(p,c));console.log('watching...')\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "sidebar",
    "sessions"
  ],
  "license": "MIT",
  "author": "ykocaman",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ykocaman/opencode-session-tracker.git"
  },
  "engines": {
    "opencode": ">=1.4.3"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.18.0",
    "@opentui/core": "^0.4.3",
    "@opentui/solid": "^0.4.3",
    "node-telegram-bot-api": "^0.66.0",
    "solid-js": "^1.9.14"
  },
  "devDependencies": {
    "@types/node-telegram-bot-api": "^0.64.15"
  }
}
